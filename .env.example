# Blockchain Configuration (BSC Testnet)
NETWORK_NAME=BSC Testnet
RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545
AGENT_PRIVATE_KEY=your_private_key_here
AGENT_ADDRESS=your_agent_wallet_address_here
CONTRACT_ADDRESS=0x... # Your ERC-8004 Identity Contract
EVM_CHAIN_ID=97
BASE_CHAIN_ID=97
NATIVE_SYMBOL=TBNB
BLOCK_EXPLORER_TX_BASE=https://testnet.bscscan.com/tx/
AUTO_RECORD_ARBITRAGE=false

# Open Travel Scout
NOMINATIM_API_BASE=https://nominatim.openstreetmap.org
OVERPASS_API_BASE=https://overpass.openstreetmap.fr/api/interpreter
NOMAD_HTTP_USER_AGENT=NomadArbiter/0.1 (open travel scout; local dev)
NOMAD_HTTP_EMAIL=
# Shown in GET /health and OpenAPI info.version (optional)
NOMAD_VERSION=0.1.0

# Local LLM
OLLAMA_MODEL=llama3.2:1b
OLLAMA_API_BASE=http://127.0.0.1:11434
LLAMA_CPP_BIN_DIR=tools/llama.cpp

# Hosted Compute Lanes
HF_TOKEN=
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
NOMAD_MODAL_APP_NAME=nomad-agent
NOMAD_MODAL_API_LABEL=nomad-agent-api
NOMAD_MODAL_SECRET_NAME=nomad-env
NOMAD_MODAL_PYTHON_VERSION=3.12
NOMAD_MODAL_ENVIRONMENT=
NOMAD_MODAL_API_PORT=8787
XAI_API_KEY=
NOMAD_XAI_BASE_URL=https://api.x.ai/v1
NOMAD_XAI_MODEL=grok-4.20-reasoning
NOMAD_XAI_MODEL_CANDIDATES=grok-4.20-reasoning,grok-4.20,grok-4-1-fast
OPENROUTER_API_KEY=
NOMAD_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
NOMAD_OPENROUTER_MODEL=openai/gpt-4o-mini
NOMAD_OPENROUTER_MODEL_CANDIDATES=openai/gpt-4o-mini,openai/gpt-4.1-mini,google/gemini-2.0-flash-001
# GitHub Models: use a fine-grained PAT with Models: Read in
# GITHUB_PERSONAL_ACCESS_TOKEN or GITHUB_TOKEN.
NOMAD_GITHUB_MODEL=openai/gpt-4.1
NOMAD_GITHUB_MODEL_CANDIDATES=openai/gpt-4.1,openai/gpt-4o,openai/gpt-4o-mini
NOMAD_GITHUB_MODELS_BASE_URL=https://models.github.ai/inference
NOMAD_GITHUB_MODELS_CATALOG_URL=https://models.github.ai/catalog/models
NOMAD_HF_MODEL=meta-llama/Llama-3.1-8B-Instruct:cerebras
NOMAD_GITHUB_MODELS_API_VERSION=2026-03-10
NOMAD_SELF_IMPROVE_MAX_TOKENS=700
NOMAD_SELF_IMPROVE_TIMEOUT_SECONDS=25
NOMAD_OLLAMA_SELF_IMPROVE_MODEL=
NOMAD_OLLAMA_AUTO_SELECT_SELF_IMPROVE_MODEL=true
NOMAD_OLLAMA_SELF_IMPROVE_MODEL_CANDIDATES=qwen2.5:0.5b-instruct,qwen2.5:1.5b-instruct,llama3.2:1b
NOMAD_OLLAMA_TIMEOUT_SECONDS=15
NOMAD_OLLAMA_MAX_TOKENS=180
NOMAD_CODEBUDDY_ENABLED=false
CODEBUDDY_API_KEY=
# Leave empty for CodeBuddy International. Only set internal/ioa for an explicitly approved China or Tencent-internal route.
CODEBUDDY_INTERNET_ENVIRONMENT=
NOMAD_CODEBUDDY_ALLOW_DIFF_UPLOAD=false
NOMAD_OPERATOR_GRANT=
NOMAD_OPERATOR_GRANT_VERSION=
NOMAD_OPERATOR_GRANT_SCOPE=
# Bounded operator actions. `human_outreach` means public/professional, value-first, non-repetitive contact only; not DMs/email/private communities.
# `public_pr_plan` means PR/repro plans, not maintainer impersonation. `autonomous_continuation` means local bounded self-development when unattended.
NOMAD_OPERATOR_GRANT_ACTIONS=
# Optional wedge for `python nomad_cli.py autonomy-step` (else NOMAD_GROWTH_LEAD_QUERY or built-in default).
NOMAD_AUTONOMY_LEAD_QUERY=
# After /leads scout, push GitHub-derived prospects into swarm (repo /.well-known/agent-card.json guess). 0=off.
NOMAD_SWARM_FEED_SCOUT_LEADS=1
NOMAD_SWARM_FEED_LEADS_LIMIT=8
NOMAD_MUTUAL_AID_AUTO_APPLY_SCORE=3
NOMAD_MUTUAL_AID_AUTO_APPLY_TRUTH=0.1
NOMAD_MUTUAL_AID_PACK_MIN_PATTERN_COUNT=2
NOMAD_AUTOPILOT_SERVICE_APPROVAL=draft_only
APPROVE_SELF_DEV=
SCOUT_PERMISSION=
APPROVE_LEAD_HELP=draft_only
NOMAD_CODEBUDDY_ACTIVE_SELF_REVIEW=false
NOMAD_CODEBUDDY_SELF_REVIEW_PATHS=nomad_codebuddy.py,workflow.py,nomad_cli.py,telegram_bot.py,infra_scout.py,self_improvement.py,test_nomad_codebuddy.py,test_control_surfaces.py,README.md,.env.example
NOMAD_CODEBUDDY_REVIEW_TIMEOUT_SECONDS=90
NOMAD_CODEBUDDY_REVIEW_MAX_DIFF_CHARS=60000
NOMAD_AUTO_CYCLE=false
NOMAD_AUTO_CYCLE_INTERVAL_MINUTES=120
NOMAD_AUTO_CYCLE_RUN_ON_START=true

NOMAD_API_HOST=127.0.0.1
NOMAD_API_PORT=8787
# Public hosting:
# - local/dev: keep 127.0.0.1 and use Cloudflare Quick Tunnel or Codespaces public port
# - GitHub syndiode branch → Render (this repo): see render.yaml — after deploy, set public URLs to the
#   live edge: https://syndiode.com/nomad (so AgentCard, swarm, x402 links match what agents can reach).
# - Render/free hosted API: NOMAD_API_HOST=0.0.0.0, Render sets PORT; NOMAD_PUBLIC_API_URL and
#   NOMAD_COLLABORATION_HOME_URL should both be https://syndiode.com/nomad for the syndiode.com path edge.
# - public edge with path prefix: point both NOMAD_PUBLIC_API_URL and
#   NOMAD_COLLABORATION_HOME_URL at the public Nomad base, e.g. https://syndiode.com/nomad
# - Cloudflare Named Tunnel: set NOMAD_PUBLIC_API_URL to the stable hostname and
#   NOMAD_CLOUDFLARE_TUNNEL_TOKEN to the tunnel token before running the public autopilot script
NOMAD_PUBLIC_API_URL=http://127.0.0.1:8787
NOMAD_OUTBOUND_AGENT_COLLABORATION_ENABLED=false
NOMAD_ACCEPT_AGENT_HELP=false
NOMAD_LEARN_FROM_AGENT_REPLIES=false
NOMAD_AGENT_COLLABORATION_MODE=public_agent_help_exchange
# Match NOMAD_PUBLIC_API_URL on production (see render.yaml, typically https://syndiode.com/nomad).
NOMAD_COLLABORATION_HOME_URL=
# Production source repo for syndiode.com (same as Render GitHub connection).
NOMAD_GITHUB_REPOSITORY=Asti1982/syndiode
NOMAD_GITHUB_DEPLOY_BRANCH=syndiode
NOMAD_CLOUDFLARE_TUNNEL_TOKEN=
RENDER_API_KEY=
# Optional alias if you prefer not to use the vendor-prefixed name alone:
# NOMAD_RENDER_API_KEY=
NOMAD_RENDER_DEPLOY_ENABLED=false
NOMAD_RENDER_OWNER_ID=
NOMAD_RENDER_SERVICE_NAME=nomad-api
NOMAD_RENDER_SERVICE_ID=
# Render custom hostname for API/dashboard calls (see render.yaml); separate from path edge syndiode.com/nomad.
NOMAD_RENDER_DOMAIN=onrender.syndiode.com
NOMAD_RENDER_ROOT_DOMAIN=syndiode.com
NOMAD_RENDER_TIMEOUT_SECONDS=12
NOMAD_CLI_ENABLED=true
NOMAD_MCP_ENABLED=true
# When true, stateful MCP tools (send/spend/verify/...) reject tools/call if tenant_id or correlation_id is missing in arguments.
NOMAD_MCP_STRICT_CONTEXT=false
# Attach nomad_wire_diag to HTTP JSON responses (skipped for /openapi*). Set 0 to disable.
NOMAD_HTTP_WIRE_DIAG=1
NOMAD_AGENT_NAME=LoopHelper
# Optional stable id for `python nomad_cli.py swarm-helper` (else default nomad.swarm_helper.v1).
NOMAD_SWARM_HELPER_AGENT_ID=
# Optional id for `python nomad_cli.py network-steward` (falls back to NOMAD_SWARM_HELPER_AGENT_ID).
NOMAD_NETWORK_STEWARD_AGENT_ID=
# Optional: hex sha256 from `python nomad_cli.py void-observer --json` edge_coherence_sha256; drift sets baseline_drift.
NOMAD_VOID_OBSERVER_BASELINE_SHA256=
# Optional path for `python nomad_cli.py machine-blind-spots --append-log` (default nomad_autonomous_artifacts/edge_coherence.jsonl).
NOMAD_EDGE_COHERENCE_LOG=
# Optional JSONL for `python nomad_cli.py lead-product-blind-spots --append-log`.
NOMAD_LEAD_COHERENCE_LOG=
# Lead scout: optional focus profile id in nomad_lead_sources.json (e.g. compute_auth, agent_infra_prime, balanced).
# NOMAD_LEAD_FOCUS=
# Boost score for agent-critical service types (turn parity, MCP routing, context envelope, chain budget, prod MCP, mis-blame).
# NOMAD_LEAD_AGENT_INFRA_FOCUS_BOOST=2.4
# Tie-break in _recommended_service_type toward those types when scores are close.
# NOMAD_LEAD_AGENT_INFRA_CLASSIFIER_BIAS=1.4
# When true, qualified leads with agent-critical recommended_service_type sort above other qualified leads at same tier.
# NOMAD_LEAD_PRIORITIZE_AGENT_INFRA=1
# Optional default tail line count for agent-retry-coach (CLI --tail-lines overrides when passed).
NOMAD_AGENT_RETRY_COACH_TAIL=96
NOMAD_AGENT_VERSION=0.1.0
NOMAD_A2A_PROTOCOL_VERSION=0.3.0
NOMAD_ADDON_DIR=Nomadds
NOMAD_QUANTUM_TOKENS_ENABLED=true
NOMAD_ALLOW_REAL_QUANTUM=false
NOMAD_QUANTUM_BACKEND=local_classical_statevector
IBM_QUANTUM_TOKEN=
QUANTUM_INSPIRE_TOKEN=
QI_API_TOKEN=
AZURE_QUANTUM_TOKEN=
GOOGLE_QUANTUM_TOKEN=
NOMAD_ALLOW_HPC_SUBMIT=false
EUROHPC_PROJECT_ID=
EUROHPC_USERNAME=
EGI_PROJECT_ID=
EGI_ACCESS_TOKEN=
EGI_VO=
DENBI_PROJECT_ID=
DENBI_USERNAME=
HPC_SSH_HOST=
HPC_SLURM_ACCOUNT=
HPC_SUBMIT_ENDPOINT=
NOMAD_SERVICE_MIN_NATIVE=0.01
NOMAD_REQUIRE_SERVICE_PAYMENT=true
NOMAD_ACCEPT_UNVERIFIED_SERVICE_PAYMENTS=false
NOMAD_SERVICE_TREASURY_STAKE_BPS=3000
NOMAD_SERVICE_SOLVER_SPEND_BPS=7000
NOMAD_TREASURY_STAKING_TARGET=metamask_eth_staking
NOMAD_X402_ENABLED=true
NOMAD_X402_FACILITATOR_URL=https://x402.org/facilitator
NOMAD_X402_FACILITATOR_BEARER_TOKEN=
NOMAD_X402_NETWORK=eip155:84532
NOMAD_X402_ASSET_ADDRESS=
NOMAD_X402_ASSET_SYMBOL=USDC
NOMAD_X402_ASSET_DECIMALS=6
NOMAD_X402_MAX_TIMEOUT_SECONDS=60
NOMAD_AGENT_CONTACT_TIMEOUT_SECONDS=12
NOMAD_COLD_OUTREACH_LIMIT=100
NOMAD_COLD_OUTREACH_DELAY_SECONDS=1.0
NOMAD_AGENT_DISCOVERY_SEEDS=
NOMAD_AUTOPILOT_CONVERSION_LIMIT=5
NOMAD_AUTOPILOT_DAILY_LEAD_TARGET=100
NOMAD_AUTOPILOT_A2A_SEND=false
# When true, autopilot cold-contacts public machine-readable agent endpoints (GitHub discovery). Requires NOMAD_PUBLIC_API_URL to a live /service + /tasks surface.
NOMAD_AUTOPILOT_SEND_OUTREACH=false
NOMAD_AUTOPILOT_OUTREACH_LIMIT=10
# Pipe-separated GitHub code search queries (include agent-card, .well-known, mcp, and/or openclaw for OpenClaw-style MCP configs).
# NOMAD_AUTOPILOT_OUTREACH_QUERIES="agent-card.json" "mcp" "https://" | "openclaw" "mcp" "https://"
# Cold outreach wire format: unset uses nomad.outreach.v3 when NOMAD_OUTREACH_SERVICE_TYPE=inter_agent_witness (peer-agent contract + peer_contract_url). Set v1 or off to force legacy v1 lines.
# NOMAD_PEER_OUTREACH_SCHEMA=v1
NOMAD_AUTOPILOT_SERVICE_LIMIT=25
# Optional second pass: GitHub-shaped scout → conversion → products → swarm (operational growth). Default off (duplicates scout vs self_improvement lead_scout).
NOMAD_AUTOPILOT_AGENT_GROWTH_PIPELINE=false
NOMAD_AUTOPILOT_AGENT_GROWTH_EVERY_N_CYCLES=1
NOMAD_AUTOPILOT_AGENT_GROWTH_QUERY=
NOMAD_AUTOPILOT_AGENT_GROWTH_LIMIT=5
NOMAD_AUTOPILOT_AGENT_GROWTH_SEND=false
NOMAD_AUTOPILOT_AGENT_GROWTH_NO_PRODUCTS=false
NOMAD_AUTOPILOT_AGENT_GROWTH_NO_SWARM_FEED=false

# Arbiter Identity (GitHub & Email)
GITHUB_USERNAME=arbiteragent
GITHUB_EMAIL=
GITHUB_PASSWORD=
GITHUB_TOKEN=
GITHUB_PERSONAL_ACCESS_TOKEN=

# Email Service (Mail.tm)
MAIL_TM_TOKEN=

# Telegram Bot Token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_STATUS_UPDATES=true
TELEGRAM_STATUS_INTERVAL_MINUTES=25
TELEGRAM_STATUS_CHAT_IDS=
TELEGRAM_STATUS_CHANGE_ONLY=true
TELEGRAM_AUTO_CYCLE_CHANGE_ONLY=true
TELEGRAM_STATUS_REPEAT_DIGEST_EVERY=0
TELEGRAM_AUTO_CYCLE_REPEAT_DIGEST_EVERY=0
TELEGRAM_DELETE_TOKEN_MESSAGES=true
TELEGRAM_AUTO_SUBSCRIBE_ON_INTERACTION=false
# Short human-friendly digests for /status, periodic status, and auto-cycle pushes. Set false for long technical Telegram (legacy).
TELEGRAM_HUMAN_SIGNALS=true

